{
  "rewrites": [
    {
      "source": "/prospects/:categoria/:slug/(.*)",
      "destination": "/prospects/:categoria/:slug/index.html"
    },
    {
      "source": "/prospects/:categoria/:slug",
      "destination": "/prospects/:categoria/:slug/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ]
}